# --- Storefront (Vite / TanStack Start) ---
# Leave these unset to run the storefront on the local seed catalog.
# Set them to read live content from your Sanity project.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-10-01

# --- Sanity Studio (sanity CLI) ---
# Required only when running the embedded Studio (`pnpm studio`).
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
